{
  "name": "esim-installer",
  "version": "1.0.0",
  "description": "Capacitor plugin for zero-QR eSIM installation on iOS and Android",
  "main": "dist/plugin.cjs.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "unpkg": "dist/plugin.js",
  "files": [
    "android/src/main/",
    "android/build.gradle",
    "dist/",
    "ios/Plugin/",
    "EsimInstaller.podspec"
  ],
  "capacitor": {
    "ios": {
      "src": "ios"
    },
    "android": {
      "src": "android"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "@capacitor/core": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/core": "^6.0.0",
    "typescript": "^5.5.0"
  }
}
